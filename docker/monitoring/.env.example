# Copia questo file in docker/monitoring/.env (ignorato da git) sul VPS.

# Host pubblico di Grafana (serve un DNS che punti al VPS; con DuckDNS
# i sottodomini wildcard *.nome.duckdns.org risolvono già).
GRAFANA_HOST=grafana.example.duckdns.org

# Credenziali admin di Grafana (password robusta: openssl rand -hex 16)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=

# Utente MySQL dedicato al monitoraggio (creato con i soli grant:
# PROCESS, REPLICATION CLIENT, SELECT su performance_schema)
MYSQLD_EXPORTER_USER=exporter
MYSQLD_EXPORTER_PASSWORD=

# Nome della network Docker dello stack app (project name + _app_internal)
APP_NETWORK=yii3-template-prod_app_internal
