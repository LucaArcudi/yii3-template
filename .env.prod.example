COMPOSE_PROJECT_NAME=yii3-template-prod

# Published application image.
APP_IMAGE=ghcr.io/lucaarcudi/yii3-template:latest

# Public host handled by the Docker/Caddy reverse proxy labels.
PROD_HOST=app.example.com
SERVER_NAME=:80
APP_PORT=8080

# Secret key used to encrypt/sign cookies (e.g. the auto-login cookie).
# Required in production: generate one with `openssl rand -hex 32`.
AUTH_COOKIE_SECRET_KEY=replace-with-random-32-byte-secret

# Trusted proxies for X-Forwarded-* headers (IPs, CIDR ranges or the
# aliases "private"/"localhost"). Leave unset for the default, which
# covers the Caddy reverse proxy on the private Docker networks.
# TRUSTED_PROXY_IPS=private,localhost

# Database configuration. Replace passwords in the real .env.prod file.
DB_DATABASE=yii3_template
DB_USERNAME=yii3_template
DB_PASSWORD=replace-with-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

# Optional: local-only DB forward on the VPS, used through an SSH tunnel.
DB_FORWARD_HOST=127.0.0.1
DB_FORWARD_PORT=3307
